---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Daniel Grigore">
  <section class="max-w-2xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-semibold mb-8 text-text-primary">Get in touch</h1>

    <div class="space-y-8">
      <div>
        <h2 class="text-lg font-semibold text-text-primary mb-3">Email</h2>
        <a href="mailto:gri.daniel@gmail.com" class="text-accent text-lg hover:opacity-80 transition-opacity">
          gri.daniel@gmail.com
        </a>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-text-primary mb-3">Phone</h2>
        <a href="tel:+40729176838" class="text-accent text-lg hover:opacity-80 transition-opacity">
          +40 729 176 838
        </a>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-text-primary mb-3">LinkedIn</h2>
        <a href="https://linkedin.com/in/grigoreDaniel/" target="_blank" class="text-accent text-lg hover:opacity-80 transition-opacity">
          linkedin.com/in/grigoreDaniel/
        </a>
      </div>

      <div class="pt-8 border-t border-bg-border">
        <h2 class="text-lg font-semibold text-text-primary mb-3">Location</h2>
        <p class="text-text-secondary">
          Bucharest, Romania<br/>
          <span class="text-sm">Remote — willing to travel 1-2 times per year for onsite meetings</span>
        </p>
      </div>
    </div>

    <div class="mt-12 p-6 bg-bg-surface border border-bg-border rounded-lg">
      <p class="text-text-secondary mb-3">
        <strong>What I'm looking for:</strong>
      </p>
      <ul class="text-text-secondary space-y-2 text-sm">
        <li>✓ Consulting engagements (short-term projects, architecture reviews)</li>
        <li>✓ Fractional advisory roles (ongoing, 10-20 hours/week)</li>
        <li>✓ Managed services work (designing and running infrastructure for clients)</li>
        <li>✓ Partnerships with MSPs and system integrators</li>
      </ul>
    </div>
  </section>
</BaseLayout>
