---
import fs from 'fs';
import path from 'path';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const workDir = path.join(process.cwd(), 'src/content/work');
  const files = fs.readdirSync(workDir).filter((f) => f.endsWith('.md'));

  return files.map((file) => ({
    params: { slug: file.replace('.md', '') },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.params as Props;
const filePath = path.join(process.cwd(), `src/content/work/${slug}.md`);
const content = fs.readFileSync(filePath, 'utf-8');

const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---/);
let frontmatter = {};
let markdown = content;

if (frontmatterMatch) {
  const fm = frontmatterMatch[1];
  frontmatter = Object.fromEntries(
    fm.split('\n').map((line) => {
      const [key, ...valueParts] = line.split(':');
      const value = valueParts.join(':').trim().replace(/^"(.*)"$/, '$1');
      return [key.trim(), value];
    })
  );
  markdown = content.replace(/^---\n[\s\S]*?\n---\n/, '');
}

const fm = frontmatter as any;
---

<PostLayout title={fm.title} description={fm.description}>
  <Fragment set:html={markdown} />
</PostLayout>
