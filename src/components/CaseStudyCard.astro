---
interface Props {
  title: string;
  description: string;
  slug: string;
}

const { title, description, slug } = Astro.props;
---

<a href={`/work/${slug}`} class="group">
  <div class="bg-bg-surface border border-bg-border rounded-lg p-6 group-hover:border-accent/50 transition-colors">
    <h3 class="text-lg font-semibold mb-2 text-text-primary group-hover:text-accent transition-colors">{title}</h3>
    <p class="text-text-secondary text-sm leading-relaxed">{description}</p>
    <div class="mt-4 text-accent text-sm font-medium group-hover:translate-x-1 transition-transform">
      Read more →
    </div>
  </div>
</a>
