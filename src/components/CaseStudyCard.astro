---
interface Props {
  title: string;
  description: string;
  slug: string;
}

const { title, description, slug } = Astro.props;
---

<a href={`/work/${slug}`} class="group block h-full">
  <div class="bg-bg-surface border border-bg-border rounded-lg p-8 h-full group-hover:border-accent/50 transition-all duration-300 group-hover:shadow-lg group-hover:shadow-accent/10 flex flex-col relative overflow-hidden">
    <!-- Accent bar on hover -->
    <div class="absolute top-0 left-0 w-1 h-full bg-accent transform origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-300"></div>

    <h3 class="text-lg font-semibold mb-3 text-text-primary group-hover:text-accent transition-colors">{title}</h3>
    <p class="text-text-secondary text-sm leading-relaxed flex-grow">{description}</p>

    <div class="mt-6 flex items-center text-accent text-sm font-medium group-hover:translate-x-1 transition-transform duration-200">
      Read more
      <span class="ml-2 inline-block group-hover:translate-x-1 transition-transform duration-200">→</span>
    </div>
  </div>
</a>
