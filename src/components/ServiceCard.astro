---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="group bg-bg-surface border border-bg-border rounded-lg p-8 hover:border-accent/50 transition-all hover:shadow-lg hover:shadow-accent/10">
  <div class="mb-6 text-accent group-hover:scale-110 transition-transform duration-300 inline-block">
    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      {icon === 'consulting' && (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      )}
      {icon === 'itsm' && (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      )}
      {icon === 'managed' && (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v5a2 2 0 01-2 2M5 12a2 2 0 00-2 2v5a2 2 0 002 2h14a2 2 0 002-2v-5a2 2 0 00-2-2m0 0H9m0 0a2 2 0 01-2 2h2a2 2 0 01-2-2m0 0H5" />
      )}
    </svg>
  </div>
  <h3 class="text-lg font-semibold mb-3 text-text-primary group-hover:text-accent transition-colors">{title}</h3>
  <p class="text-text-secondary leading-relaxed text-sm">{description}</p>
</div>
